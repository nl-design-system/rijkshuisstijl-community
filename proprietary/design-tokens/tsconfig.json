{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "target": "ES2022",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "include": ["**/*.mts", "**/*.ts", "token-transformer.mjs"],
  "exclude": ["node_modules", "dist"]
}
